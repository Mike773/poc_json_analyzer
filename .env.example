# Скопируйте в .env и заполните. Скрипты подхватывают .env автоматически.

# Провайдер LLM/embeddings: openai | gigachat
LLM_PROVIDER=gigachat

# Имя чат-модели (необязательно). Если не задано — дефолт провайдера.
# openai: o4-mini | gigachat: GigaChat-Max
LLM_MODEL=GigaChat-2-Max

# --- GigaChat ---
# Ключ авторизации (base64 client_id:client_secret) из кабинета GigaChat.
GIGACHAT_CREDENTIALS=
# Тариф: GIGACHAT_API_PERS (физлица) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# --- OpenAI ---
# OPENAI_API_KEY=sk-...

# --- Postgres (опциональный pgvector-кеш поиска метрик) ---
# POC_PG_DSN=postgresql://poc:poc@localhost:5434/poc_metrics
